{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "python -m bot.main",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "envVars": {
      "AGENT_COUNT": {
        "description": "Jumlah agent yang berjalan sekaligus (1-10)",
        "default": "10"
      },
      "RAILWAY_API_TOKEN": {
        "description": "Railway API Token (Wajib untuk auto-sync!)",
        "required": true
      },
      "ROOM_MODE": {
        "description": "Mode room: free / auto / paid",
        "default": "free"
      },
      "LOG_LEVEL": {
        "description": "Level logging: DEBUG / INFO / WARNING",
        "default": "INFO"
      },
      "ADVANCED_MODE": {
        "description": "Auto-generate Owner+Agent wallets",
        "default": "true"
      },
      "AUTO_WHITELIST": {
        "description": "Auto-check whitelist",
        "default": "true"
      },
      "AUTO_SC_WALLET": {
        "description": "Auto-create SC Wallet",
        "default": "true"
      },
      "ENABLE_MEMORY": {
        "description": "Enable cross-game learning",
        "default": "true"
      },
      "AUTO_IDENTITY": {
        "description": "Auto-register identity",
        "default": "true"
      },
      "AGENT_1_NAME": { "default": "lolali-01" },
      "AGENT_2_NAME": { "default": "lolali-02" },
      "AGENT_3_NAME": { "default": "lolali-03" },
      "AGENT_4_NAME": { "default": "lolali-04" },
      "AGENT_5_NAME": { "default": "lolali-05" },
      "AGENT_6_NAME": { "default": "lolali-06" },
      "AGENT_7_NAME": { "default": "lolali-07" },
      "AGENT_8_NAME": { "default": "lolali-08" },
      "AGENT_9_NAME": { "default": "lolali-09" },
      "AGENT_10_NAME": { "default": "lolali-10" }
    }
  }
}
